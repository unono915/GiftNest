{
  "name": "giftnest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "hash-pin": "tsx scripts/hash-pin.ts",
    "emulators": "firebase emulators:start --only firestore,storage,auth",
    "test:rules": "firebase emulators:exec --only firestore,storage,auth \"vitest run --config vitest.rules.config.ts\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@hookform/resolvers": "^3.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^0.469.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "firebase-tools": "^13.29.1",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "prompts": "^2.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
