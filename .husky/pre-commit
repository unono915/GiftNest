#!/usr/bin/env sh
set -e

echo "[pre-commit] Checking for files that must never be committed..."

BLOCKED_PATTERN='(^|/)\.env($|\.)|(^|/)(firebase-adminsdk|.*service-account.*)\.json$|(^|/)GiftNest_PRD.*\.md$|(^|/)planning/|(^|/)local-data/'
STAGED_BLOCKED=$(git diff --cached --name-only | grep -E "$BLOCKED_PATTERN" | grep -Ev '(^|/)\.env\.example$' || true)

if [ -n "$STAGED_BLOCKED" ]; then
  echo "[pre-commit] BLOCKED: the following staged files must not be committed:"
  echo "$STAGED_BLOCKED"
  echo "[pre-commit] Unstage them with: git restore --staged <file>"
  exit 1
fi

echo "[pre-commit] Checking staged diff for the default PIN literal (1171)..."
# .gitleaks.toml and this hook legitimately describe the policy (and its detection
# regex) using the digits "1171"; everything else must never contain the literal.
PIN_LITERAL_HIT=$(git diff --cached -- . ':(exclude).gitleaks.toml' ':(exclude).husky/pre-commit' \
  | grep -E '^\+' | grep -Ei '1171' || true)
if [ -n "$PIN_LITERAL_HIT" ]; then
  echo "[pre-commit] BLOCKED: staged changes contain the literal '1171'."
  echo "[pre-commit] The default family PIN must never appear in source, tests, README, or commits."
  echo "$PIN_LITERAL_HIT"
  exit 1
fi

echo "[pre-commit] Running Gitleaks..."
GITLEAKS_BIN=""
if command -v gitleaks >/dev/null 2>&1; then
  GITLEAKS_BIN="gitleaks"
elif [ -x "/c/Users/user/AppData/Local/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe" ]; then
  GITLEAKS_BIN="/c/Users/user/AppData/Local/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe"
fi

if [ -z "$GITLEAKS_BIN" ]; then
  echo "[pre-commit] WARNING: gitleaks binary not found on PATH. Install it (winget install Gitleaks.Gitleaks) before pushing."
  echo "[pre-commit] Skipping gitleaks scan for this commit — do not rely on this as your only safety net."
else
  "$GITLEAKS_BIN" protect --staged --redact --config .gitleaks.toml
fi

echo "[pre-commit] All checks passed."
